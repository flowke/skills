# 扫码登录第三方网站专用 appId / appSecret
# 注意：这通常不是你当前消息发送所用的 appkey/appsecret。
YACH_OAUTH_APP_ID=
YACH_OAUTH_APP_SECRET=

# 必须与申请扫码登录应用时登记的回调地址保持一致（域名也要一致）
# 本地调试示例： http://127.0.0.1:8787/oauth/callback
YACH_OAUTH_REDIRECT_URI=http://127.0.0.1:8787/oauth/callback

# 可选：如果你已经有 quick_login_sign 所需的接口 access_token，可直接填这里
# 若留空，服务端会尝试用 appId/appSecret 走 /gettoken 作为兜底（这一步是推断实现，不保证所有租户都适用）
YACH_OAUTH_API_TOKEN=

# 本地服务端口
PORT=8787
